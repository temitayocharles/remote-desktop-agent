# Runner-only configuration. Do not put Telegram bot or control-plane bot credentials here.
CONTROL_PLANE_URL=http://127.0.0.1:8080
RUNNER_ID=replace-with-a-unique-runner-id
RUNNER_TOKEN=replace-with-a-long-random-runner-token
RUNNER_OS=windows
RUNNER_POLL_SECONDS=3
RUNNER_ARTIFACT_DIR=~/TelegramOperatorAgent/artifacts
RUNNER_PID_FILE=~/TelegramOperatorAgent/runner.pid
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
TASK_TIMEOUT_SECONDS=900
BROWSER_PROFILE_DIR=~/TelegramOperatorAgent/browser-profile
BROWSER_HEADLESS=false
BROWSER_TIMEOUT_SECONDS=600
