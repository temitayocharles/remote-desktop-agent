# Control-plane and Telegram configuration.
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_USER_ID=
# Host-side runners must use the host-published port. Docker services use their own internal URL.
CONTROL_PLANE_URL=http://127.0.0.1:8080
CONTROL_PLANE_BOT_TOKEN=replace-with-a-long-random-bot-token
DATABASE_URL=sqlite:////app/data/agent.db
RUNNER_ID=charles-mac
RUNNER_TOKEN=replace-with-a-long-random-runner-token
RUNNER_OS=macos
RUNNER_POLL_SECONDS=3
RUNNER_ARTIFACT_DIR=./artifacts
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1-mini
RUNNER_OFFLINE_AFTER_SECONDS=20
APPROVAL_TTL_SECONDS=900
TASK_TIMEOUT_SECONDS=900
BROWSER_PROFILE_DIR=~/.telegram-operator-agent/browser-profile
BROWSER_HEADLESS=false
BROWSER_TIMEOUT_SECONDS=600
LOG_LEVEL=INFO
